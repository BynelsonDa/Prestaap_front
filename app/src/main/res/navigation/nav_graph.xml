<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/zonasFragment">

    <fragment
        android:id="@+id/zonasFragment"
        android:name="com.example.prestaap.ui.ZonasFragment"
        android:label="Tus Zonas">
        <action
            android:id="@+id/action_zonas_to_clientes"
            app:destination="@id/clientesFragment" />
    </fragment>

    <fragment
        android:id="@+id/clientesFragment"
        android:name="com.example.prestaap.ui.ClientesFragment"
        android:label="Clientes">
        <action
            android:id="@+id/action_clientesFragment_to_clienteCreditosFragment"
            app:destination="@id/clienteCreditosFragment" />
    </fragment>

    <fragment
        android:id="@+id/nuevoClienteFragment"
        android:name="com.example.prestaap.ui.NuevoClienteFragment"
        android:label="Nuevo Cliente"
        tools:layout="@layout/fragment_nuevo_cliente" />

    <action
        android:id="@+id/action_global_nuevoClienteFragment"
        app:destination="@id/nuevoClienteFragment"
        app:launchSingleTop="true" />

    <action
        android:id="@+id/action_global_seleccionarClienteFragment"
        app:destination="@id/seleccionarClienteFragment"
        app:launchSingleTop="true" />

    <fragment
        android:id="@+id/seleccionarClienteFragment"
        android:name="com.example.prestaap.ui.SeleccionarClienteFragment"
        android:label="Seleccionar Cliente"
        tools:layout="@layout/fragment_seleccionar_cliente">
        <action
            android:id="@+id/action_seleccionarClienteFragment_to_crearCreditoFragment"
            app:destination="@id/crearCreditoFragment" />
    </fragment>

    <fragment
        android:id="@+id/crearCreditoFragment"
        android:name="com.example.prestaap.ui.CrearCreditoFragment"
        android:label="Crear Crédito"
        tools:layout="@layout/fragment_crear_credito">
        <argument android:name="clienteCedula" app:argType="long" />
        <argument android:name="clienteNombre" app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/clienteCreditosFragment"
        android:name="com.example.prestaap.ui.ClienteCreditosFragment"
        android:label="Créditos"
        tools:layout="@layout/fragment_cliente_creditos">
        <argument android:name="nombreCliente" app:argType="string" />
        <argument android:name="clienteId"     app:argType="integer" />
        <action
            android:id="@+id/action_clienteCreditosFragment_to_clienteDetalleFragment"
            app:destination="@id/clienteDetalleFragment" />
        <action
            android:id="@+id/action_clienteCreditosFragment_to_creditoDetalleFragment"
            app:destination="@id/creditoDetalleFragment" />
    </fragment>

    <fragment
        android:id="@+id/clienteDetalleFragment"
        android:name="com.example.prestaap.ui.ClienteDetalleFragment"
        android:label="Cliente"
        tools:layout="@layout/fragment_cliente_detalle">
        <argument android:name="nombre"           app:argType="string" />
        <argument android:name="cedula"            app:argType="string" />
        <argument android:name="telefono"          app:argType="string" />
        <argument android:name="direccion"         app:argType="string" />
        <argument android:name="montoTotal"        app:argType="long"    />
        <argument android:name="creditosPrestados" app:argType="integer" />
    </fragment>

    <fragment
        android:id="@+id/creditoDetalleFragment"
        android:name="com.example.prestaap.ui.CreditoDetalleFragment"
        android:label="Detalle Crédito"
        tools:layout="@layout/fragment_credito_detalle">
        <argument android:name="creditoId"     app:argType="integer" />
        <argument android:name="nombre"        app:argType="string" />
        <argument android:name="estado"        app:argType="string" />
        <argument android:name="prestado"      app:argType="long" />
        <argument android:name="restante"      app:argType="long" />
        <argument android:name="cuotasPagadas" app:argType="integer" />
        <argument android:name="totalCuotas"   app:argType="integer" />
    </fragment>

</navigation>
