<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Prestaap" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.FastCredit" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/brand_blue</item>
        <item name="colorPrimaryVariant">@color/brand_blue_dark</item>
        <item name="colorOnPrimary">@color/text_white</item>
        <item name="colorSecondary">@color/brand_green</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="FastCredit" parent="" />

    <style name="FastCredit.FeatureCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="cardBackgroundColor">@color/card_bg</item>
        <item name="cardCornerRadius">14dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/card_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="FastCredit.InputLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:layout_marginBottom">6dp</item>
    </style>

    <style name="FastCredit.InputField">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:background">@drawable/bg_input_field</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/input_text</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:inputType">text</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

</resources>
