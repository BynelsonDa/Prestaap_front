<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_login.xml
    FastCredit — Login Screen
    Dark top section with logo + rounded blue panel containing form
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".LoginActivity">

    <!-- ── TOP: Logo + App name ──────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/layoutTopLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="80dp"
        android:paddingBottom="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Logo (replace with your vector drawable) -->
        <ImageView
            android:id="@+id/imgLogoLogin"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_launcher_foreground"
            android:tint="@color/brand_green"
            android:contentDescription="FastCredit logo" />

        <!-- App name -->
        <TextView
            android:id="@+id/tvAppNameLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/app_name"
            android:textColor="@color/text_white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <!-- Tagline -->
        <TextView
            android:id="@+id/tvTaglineLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/app_tagline"
            android:textColor="@color/text_light"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- ── BOTTOM PANEL: Rounded blue form container ──────────────── -->
    <ScrollView
        android:id="@+id/panelLoginBottom"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:background="@drawable/bg_panel_rounded"
        app:layout_constraintTop_toBottomOf="@id/layoutTopLogin"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="32dp">

            <!-- Welcome heading -->
            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_welcome"
                android:textColor="@color/text_white"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvLoginSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="28dp"
                android:text="@string/login_subtitle"
                android:textColor="@color/text_light"
                android:textSize="13sp" />

            <!-- ── USERNAME FIELD ── -->
            <TextView
                style="@style/FastCredit.InputLabel"
                android:text="@string/label_username" />

            <EditText
                android:id="@+id/etUsername"
                style="@style/FastCredit.InputField"
                android:hint="@string/hint_username"
                android:inputType="text"
                android:autofillHints="username" />

            <!-- ── PASSWORD FIELD ── -->
            <TextView
                style="@style/FastCredit.InputLabel"
                android:text="@string/label_password" />

            <!-- Password field with eye toggle -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="6dp">

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="14dp"
                    android:paddingEnd="48dp"
                    android:hint="@string/hint_password"
                    android:textSize="14sp"
                    android:textColor="@color/input_text"
                    android:textColorHint="@color/text_hint"
                    android:inputType="textPassword"
                    android:autofillHints="password" />

                <!-- Eye icon toggle -->
                <ImageView
                    android:id="@+id/ivPasswordToggle"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="12dp"
                    android:src="@android:drawable/ic_menu_view"
                    android:tint="@color/text_hint"
                    android:contentDescription="Mostrar contraseña"
                    android:clickable="true"
                    android:focusable="true" />

            </FrameLayout>

            <!-- Forgot password link -->
            <TextView
                android:id="@+id/tvForgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginBottom="32dp"
                android:text="@string/forgot_password"
                android:textColor="@color/text_light"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true" />

            <!-- ── LOGIN BUTTON ── -->
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="32dp"
                android:text="@string/btn_login"
                android:textColor="@color/brand_blue"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@color/text_white"
                android:stateListAnimator="@null"
                app:cornerRadius="12dp" />

            <!-- ── BOTTOM BAR: Dots ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Dot 1 -->
                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/dot_inactive"
                    android:layout_marginEnd="6dp" />

                <!-- Dot 2 — active -->
                <View
                    android:layout_width="24dp"
                    android:layout_height="8dp"
                    android:background="@drawable/dot_active"
                    android:layout_marginEnd="6dp" />

                <!-- Spacer -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <!-- "Continue" text -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_continue"
                    android:textColor="@color/text_white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="12dp" />

                <!-- Arrow FAB -->
                <FrameLayout
                    android:id="@+id/btnLoginNext"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_btn_circle_blue"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="4dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_media_next"
                        android:tint="@color/text_white"
                        android:contentDescription="Continuar" />
                </FrameLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
