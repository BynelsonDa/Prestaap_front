<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- White top bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Volver" />

        <TextView
            android:id="@+id/tvClienteNombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A" />

        <!-- Spacer to balance back arrow and keep title centered -->
        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />

    </LinearLayout>

    <!-- Tab toggle row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnACobrarHoy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="A cobrar hoy"
            android:textSize="13sp"
            app:cornerRadius="20dp"
            app:strokeWidth="1dp"
            app:strokeColor="#CCCCCC"
            app:backgroundTint="#FFFFFF"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTodosLosCreditos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Todos los créditos"
            android:textSize="13sp"
            app:cornerRadius="20dp"
            app:strokeWidth="1dp"
            app:strokeColor="#CCCCCC"
            app:backgroundTint="#FFFFFF"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>

    <!-- Secondary row: Información personal + Estado spinner -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnInfoPersonal"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Información personal"
            android:textSize="13sp"
            app:cornerRadius="20dp"
            app:strokeWidth="1dp"
            app:strokeColor="#CCCCCC"
            app:backgroundTint="#FFFFFF"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHistorialPagos"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:text="Historial pagos"
            android:textSize="13sp"
            app:cornerRadius="20dp"
            app:strokeWidth="1dp"
            app:strokeColor="#CCCCCC"
            app:backgroundTint="#FFFFFF"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <Spinner
            android:id="@+id/spinnerEstado"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_spinner_rounded" />

    </LinearLayout>

    <!-- Credits list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCreditos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="gone" />

    <!-- Bottom action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp"
        android:background="#FFFFFF">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAbonarTodo"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_margin="8dp"
            android:text="Abonar a todo"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            app:backgroundTint="#2563EB"
            app:cornerRadius="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEliminar"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_margin="8dp"
            android:text="Eliminar crédito"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            app:backgroundTint="#E53935"
            app:cornerRadius="24dp" />

    </LinearLayout>

</LinearLayout>
