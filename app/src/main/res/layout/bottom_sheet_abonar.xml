<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="20dp">

    <!-- Header: titulo + cerrar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp">

        <TextView
            android:id="@+id/tvAbonarTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registrar abono"
            android:gravity="center"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A" />

        <ImageView
            android:id="@+id/ivClose"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="end|center_vertical"
            android:src="@drawable/ic_close"
            android:contentDescription="Cerrar"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#666666" />

    </FrameLayout>

    <!-- Credito (auto-seleccionado) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_field_rounded"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tvCredito"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="14dp"
            android:text="Crédito"
            android:textSize="14sp"
            android:textColor="#212121"
            android:maxLines="1"
            android:ellipsize="end" />

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginEnd="10dp"
            android:src="@drawable/ic_chevron_down"
            android:contentDescription="@null" />

    </LinearLayout>

    <!-- Fecha (hoy por defecto, abre calendario) -->
    <LinearLayout
        android:id="@+id/layoutFecha"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_field_rounded"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvFecha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="14dp"
            android:textSize="14sp"
            android:textColor="#212121"
            android:maxLines="1" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_calendar"
            android:contentDescription="@null" />

    </LinearLayout>

    <!-- Metodo de pago: checkboxes -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Método de pago"
        android:textSize="13sp"
        android:textColor="#444444"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <CheckBox
            android:id="@+id/cbFisico"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pago en físico"
            android:textSize="14sp"
            android:textColor="#212121" />

        <CheckBox
            android:id="@+id/cbTransferencia"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Transferencia"
            android:textSize="14sp"
            android:textColor="#212121" />

    </LinearLayout>

    <!-- Banco (se despliega solo con Transferencia) -->
    <LinearLayout
        android:id="@+id/layoutBanco"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_field_rounded"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/tvBanco"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="14dp"
            android:text="Selecciona banco"
            android:textSize="14sp"
            android:textColor="#888888"
            android:maxLines="1"
            android:ellipsize="end" />

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginEnd="10dp"
            android:src="@drawable/ic_chevron_down"
            android:contentDescription="@null" />

    </LinearLayout>

    <!-- Monto a abonar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_field_rounded"
        android:layout_marginTop="16dp">

        <EditText
            android:id="@+id/etMonto"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@null"
            android:hint="Monto a abonar"
            android:textColorHint="#888888"
            android:textColor="#212121"
            android:textSize="14sp"
            android:inputType="numberDecimal"
            android:paddingHorizontal="14dp" />

    </LinearLayout>

    <!-- Boton registrar (solo diseno) -->
    <Button
        android:id="@+id/btnConfirmar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="20dp"
        android:text="Registrar abono"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2563EB"
        style="@style/Widget.MaterialComponents.Button"
        app:cornerRadius="12dp" />

</LinearLayout>
